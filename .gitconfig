[user]
	email = andreea@ieval.ro
	name = arrws

[credential]
    helper = store

[rerere]
    enabled = false

[branch]
    autosetuprebase = always

[pull]
    rebase = false

[core]
    pager = delta
    editor = vi

[interactive]
    diffFilter = delta

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default
    algorithm = histogram


[color]
    ui = auto

[color "status"]
    header = "#EEEEEE"
    branch = "#EEEEEE"
    nobranch = "#FF2020"
    added = "#00D75F"
    updated = "#00D75F"
    changed = "#33ABEF"
    untracked = "#A8A8A8"
    unmerged = "bold #FF2020"

[color "diff"]
    meta = "#33ABEF"
    old = "#FF2020"
    new = "#00D75F"

[delta]
    navigate = true
    features = delta

[delta "delta"]
    red = "#FF2020"
    red-light ="#FF5F5F"
    green = "#00D75F"
    green-light = "#77EE77"
    blue = "#33ABEF"
    black = "#000000"
    gray-dark = "#1C1C1C"
    gray = "#808080"
    white = "#EEEEEE"

    syntax-theme = "none"
    hyperlinks = true

    map-styles = \
       bold purple => delta.black, \
       bold blue => syntax delta.black, \
       bold cyan => delta.black, \
       bold yellow => syntax delta.black

    side-by-side = false

    line-numbers = true
    line-numbers-left-format = "{nm:>3} "
    line-numbers-right-format = "{np:>3} │"
    line-numbers-left-style = delta.gray
    line-numbers-right-style = delta.gray-dark
    line-numbers-minus-style = delta.red
    line-numbers-plus-style = delta.green
    line-numbers-zero-style = delta.gray

    keep-plus-minus-markers = false

    plus-non-emph-style = syntax
    plus-emph-style = delta.green-light delta.black bold
    plus-style = delta.green delta.black
    plus-empty-line-marker-style = delta.black

    minus-non-emph-style = syntax
    minus-emph-style = delta.red-light delta.black bold
    minus-style = delta.red delta.black
    minus-empty-line-marker-style = delta.black

    hunk-header-style = omit
    hunk-header-decoration-style = omit
    hunk-header-file-style = omit
    hunk-header-line-number-style = omit

    file-style = bold delta.blue
    file-decoration-style = omit
    file-added-label = >
    file-copied-label = >
    file-modified-label = >
    file-removed-label = >
    file-renamed-label = >

    inline-hint-style = omit
    whitespace-error-style = delta.black delta.gray-dark
    zero-style = syntax

    grep-file-style = delta.blue
    grep-line-number-style = delta.gray

    blame-code-style = syntax
    blame-separator-style = omit
    commit-style = delta.blue
    commit-decoration-style = omit

    merge-conflict-ours-diff-header-style = delta.blue
    merge-conflict-ours-diff-header-decoration-style = omit
    merge-conflict-theirs-diff-header-style = delta.red
    merge-conflict-theirs-diff-header-decoration-style = omit
