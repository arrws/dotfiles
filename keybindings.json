// Override key bindings by placing them into your key bindings file.
[
    { "key": "ctrl+alt+enter",             "command": "workbench.action.terminal.new", "when": "terminalProcessSupported || terminalWebExtensionContributedProfile" },
    { "key": "ctrl+alt+d",                 "command": "workbench.action.nextEditor" },
    { "key": "ctrl_alt+s",                 "command": "workbench.action.previousEditor" },
    { "key": "ctrl_alt+shift+d",           "command": "workbench.action.moveEditorRightInGroup" },
    { "key": "ctrl_alt+shift+s",           "command": "workbench.action.moveEditorLeftInGroup" },
    { "key": "ctrl_alt+x",                 "command": "workbench.action.closeActiveEditor" },

    { "key": "ctrl_alt+f",                 "command": "actions.find", "when": "editorFocus || editorIsOpen" },
    // { "key": "ctrl_alt+shift+f",           "command": "workbench.action.findInFiles" },
    { "key": "ctrl_alt+; r",               "command": "workbench.action.findInFiles" },
    // { "key": "ctrl_alt+p",                 "command": "workbench.action.quickOpen" },
    { "key": "ctrl_alt+; f",               "command": "workbench.action.quickOpen" },
    { "key": "enter",                 "command": "quickInput.accept", "when": "inQuickInput && quickInputType != 'quickWidget'" },


    { "key": "ctrl_alt+z",                 "command": "undo" },
    { "key": "ctrl_alt+shift+z",           "command": "redo" },

    { "key": "ctrl_alt+shift+\\",          "command": "-workbench.action.splitEditorDown" },
    { "key": "ctrl_alt+\\",                "command": "-workbench.action.splitEditorRight" },
]
